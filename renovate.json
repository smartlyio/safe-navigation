{
  "extends": ["config:best-practices", "config:js-lib"],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "timezone": "Europe/Helsinki",
  "prHourlyLimit": 5,
  "labels": ["patch"],
  "packageRules": [
    {
      "groupName": "Smartly packages",
      "schedule": "at any time",
      "matchPackageNames": ["/^@smartly//", "!/^@smartly/asset-/"]
    },
    {
      "groupName": "Smartly Asset Library Components",
      "schedule": "at any time",
      "matchPackageNames": ["/^@smartly/asset-/"]
    },
    {
      "groupName": "Smartly Oats",
      "schedule": "at any time",
      "matchPackageNames": ["/^@smartlyio/oats/"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "schedule": "before 8am on monday",
      "groupName": "devDependencies",
      "automerge": true,
      "labels": ["dependencies", "no release"]
    }
  ],
  "minimumReleaseAge": "30 days"
}
